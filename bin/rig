#!/usr/bin/env bash
# rig —— 给 AI coding 供给纪律的分层 harness。
# CLI 是"机械/确定性层"(检测、装全局机制、铺项目骨架、自检);
# 判断性工作(归并既有规范、推导 AGENTS 地图、写 verify-local)由 AI 读 SKILL.md 完成。
set -u
# 解析自身真实路径:经 PATH 软链(~/.local/bin/rig)或 skill 软链(~/.claude/skills/rig)调用时,
# 都要定位到真实克隆的包根,而不是软链所在目录(否则 scripts/assets 全找不到)。回归测试见 test/resolve-self.sh。
__src="${BASH_SOURCE[0]:-$0}"
while [ -h "$__src" ]; do
  __dir="$(cd -P "$(dirname "$__src")" && pwd)"
  __src="$(readlink "$__src")"
  case "$__src" in /*) ;; *) __src="$__dir/$__src" ;; esac
done
SELF="$(cd -P "$(dirname "$__src")/.." && pwd)"   # rig 包根(真实物理路径)
if [ ! -f "$SELF/scripts/detect-env.sh" ]; then
  echo "rig: 包根解析异常,$SELF 下找不到 scripts/(可能软链损坏)。请用真实克隆路径运行,如 ~/rig/bin/rig" >&2
  exit 1
fi
cmd="${1:-help}"; [ "$#" -gt 0 ] && shift

usage(){
  cat <<EOF
rig —— 给 AI coding 供给纪律的分层 harness

用法:
  rig init [--claude|--codex|--cursor] [项目目录]
      默认 auto 检测本机已装 AI 工具并补齐适配；传 --claude/--codex/--cursor 则只处理指定工具
      检测 → 装全局机制(hooks/agents/settings/hooks.json,缺才装) → 铺项目骨架(幂等不覆盖)
      判断性内容(归并既有规范 / 推导 AGENTS 地图 / 写 verify-local)交 AI 读 SKILL.md 完成
  rig doctor [项目目录]
      安装后自检:注入 / 红线拦 / 闸 / 失败降级
  rig help

包根:     $SELF
设计文档: $SELF/docs/DESIGN.md
安装细节: $SELF/docs/INSTALL.md
EOF
}

scaffold_project(){
  P="$1"
  [ -f "$P/AGENTS.md" ] || cp "$SELF/assets/project-layer/AGENTS.md" "$P/AGENTS.md"
  [ -f "$P/CLAUDE.md" ] || cp "$SELF/assets/project-layer/CLAUDE.md" "$P/CLAUDE.md"
  mkdir -p "$P/scripts"; cp -n "$SELF"/assets/project-layer/scripts/*.sh "$P/scripts/" 2>/dev/null || true
  chmod +x "$P/scripts/"*.sh 2>/dev/null || true
  mkdir -p "$P/.claude"
  cp -Rn "$SELF/assets/project-layer/.claude/commands" "$P/.claude/" 2>/dev/null || true
  cp -n "$SELF/assets/project-layer/.claude/protected-paths.txt" "$P/.claude/" 2>/dev/null || true
  mkdir -p "$P/docs"
  for d in conventions adr plans; do cp -Rn "$SELF/assets/project-layer/docs/$d" "$P/docs/" 2>/dev/null || true; done
  cp -n "$SELF/assets/project-layer/.editorconfig" "$P/" 2>/dev/null || true
  # 注:openspec/ 不在机械层无条件铺——它按需(applies_when:预研/demo=N/A)且要 openspec CLI 已装,
  # 由 AI 在判断步骤处理(见 SKILL/init.md):需求驱动型 + CLI 在 → openspec init + 拷模板;否则标缺不铺。
}

install_shared_hooks(){
  mkdir -p "$HOME/.rig/hooks"
  cp "$SELF"/assets/dotfiles-layer/hooks/*.sh "$HOME/.rig/hooks/" && chmod +x "$HOME/.rig/hooks/"*.sh
}

write_codex_hooks_json(){
  target="$1"
  dir="$(dirname "$target")"
  mkdir -p "$dir"
  base="$target.base.$$"
  tmp="$target.tmp.$$"
  inject_cmd='bash "$HOME/.codex/hooks/inject-conventions.sh" --codex'
  lint_cmd='bash "$HOME/.codex/hooks/lint-changed.sh" --codex'

  if [ -f "$target" ]; then
    if jq empty "$target" >/dev/null 2>&1; then
      cp "$target" "$base"
    else
      echo "✗ $target 不是合法 JSON；为避免覆盖你的既有配置，已停止写入。" >&2
      echo "  请先修复该文件后重跑 rig init --codex。" >&2
      return 1
    fi
  else
    printf '%s\n' '{"hooks":{}}' > "$base"
  fi

  if jq --arg inject "$inject_cmd" --arg lint "$lint_cmd" '
    .hooks = (.hooks // {}) |
    if ([.hooks.UserPromptSubmit[]?.hooks[]?.command] | index($inject)) then .
    else
      .hooks.UserPromptSubmit = ((.hooks.UserPromptSubmit // []) + [{
        hooks:[{
          type:"command",
          command:$inject,
          statusMessage:"注入项目规范...",
          timeout:45
        }]
      }])
    end |
    if ([.hooks.PostToolUse[]?.hooks[]?.command] | index($lint)) then .
    else
      .hooks.PostToolUse = ((.hooks.PostToolUse // []) + [{
        matcher:"apply_patch|Edit|Write|MultiEdit",
        hooks:[{
          type:"command",
          command:$lint,
          statusMessage:"按规范检查改动...",
          timeout:45
        }]
      }])
    end
  ' "$base" > "$tmp"; then
    mv "$tmp" "$target"
    rm -f "$base"
  else
    rm -f "$base" "$tmp"
    return 1
  fi
}

install_codex_hooks(){
  if ! command -v jq >/dev/null 2>&1; then
    echo "✗ 缺 jq（阻断级）——Codex hooks.json 合并和 hook JSON 输出都依赖 jq。" >&2
    echo "  先安装 jq 后重跑 rig init --codex。" >&2
    return 1
  fi

  install_shared_hooks || return 1
  mkdir -p "$HOME/.codex"

  if [ -e "$HOME/.codex/hooks" ] && [ ! -L "$HOME/.codex/hooks" ]; then
    mkdir -p "$HOME/.codex/hooks"
    cp "$HOME"/.rig/hooks/*.sh "$HOME/.codex/hooks/" && chmod +x "$HOME/.codex/hooks/"*.sh
  else
    ln -sfn "$HOME/.rig/hooks" "$HOME/.codex/hooks"
  fi

  write_codex_hooks_json "$HOME/.codex/hooks.json"
}

tool_available(){
  case "$1" in
    claude) [ -d "$HOME/.claude" ] || command -v claude >/dev/null 2>&1 || command -v claude-code >/dev/null 2>&1 ;;
    codex) [ -d "$HOME/.codex" ] || command -v codex >/dev/null 2>&1 || [ -d "/Applications/Codex.app" ] ;;
    cursor) [ -d "$HOME/.cursor" ] || [ -d "/Applications/Cursor.app" ] ;;
    *) return 1 ;;
  esac
}

dedupe_tools(){
  seen=""
  for t in "$@"; do
    case " $seen " in *" $t "*) ;; *) seen="$seen $t" ;; esac
  done
  printf '%s\n' "$seen" | sed 's/^ *//; s/ *$//'
}

detect_tools(){
  found=""
  for t in claude codex cursor; do
    if tool_available "$t"; then found="$found $t"; fi
  done
  printf '%s\n' "$found" | sed 's/^ *//; s/ *$//'
}

case "$cmd" in
  -h|--help|help|"") usage ;;
  doctor) bash "$SELF/scripts/verify.sh" "${1:-$PWD}" ;;
  init)
    requested_tools=""; proj="$PWD"
    for a in "$@"; do case "$a" in
      --claude) requested_tools="$requested_tools claude" ;; --codex) requested_tools="$requested_tools codex" ;; --cursor) requested_tools="$requested_tools cursor" ;;
      --*) echo "未知选项: $a" >&2; exit 1 ;;
      *) if [ -d "$a" ]; then proj="$(cd "$a" && pwd)"; else echo "rig init: 目录不存在: $a（别铺成半成品骨架）" >&2; exit 1; fi ;;
    esac; done
    if [ -n "$requested_tools" ]; then
      tools="$(dedupe_tools $requested_tools)"
      tool_label="$tools"
    else
      tools="$(detect_tools)"
      tool_label="auto:${tools:-none}"
    fi
    echo "== rig init · tools=$tool_label · project=$proj =="
    echo; echo "-- 机器画像 --"; bash "$SELF/scripts/detect-env.sh" "$proj" | sed -n '1,12p'
    echo; echo "-- 全局机制 --"
    if [ -z "$tools" ]; then
      echo "  ⚠ 未检测到 Claude/Codex/Cursor；仅铺项目 canonical 骨架。"
    fi
    for tool in $tools; do
      case "$tool" in
        claude)
          if ! bash "$SELF/scripts/bootstrap.sh"; then
            echo "⚠ Claude 全局机制未装全(bootstrap 非零退出,见上 ↑)。项目骨架仍会铺,但 hook 机制要等你修好上面的问题(常见:装 jq)后重跑 rig init 才生效。" >&2
          fi
          ;;
        codex)
          if install_codex_hooks; then
            echo "  ✓ Codex 共享 hook 脚本已就位: ~/.rig/hooks"
            echo "  ✓ Codex hook 入口已关联: ~/.codex/hooks"
            echo "  ✓ Codex hook 注册已写入: ~/.codex/hooks.json"
            echo "  ⚠ 首次使用需在 Codex 的 /hooks 中 review + trust 这些 command hook；脚本变更后需重新 trust。"
          else
            echo "⚠ Codex 全局机制未装全(见上 ↑)。项目骨架仍会铺,修好前置后重跑 rig init。" >&2
          fi
          ;;
        cursor)
          echo "  ⚠ Cursor 目前仅复用 canonical(AGENTS/conventions)+CI 兜底，工具侧规则派生后续补。"
          ;;
      esac
    done
    echo; echo "-- 项目骨架(幂等,不覆盖既有) --"; scaffold_project "$proj"; echo "  骨架已就位(已存在的未动)"
    echo; echo "-- 接下来交给 AI(读 SKILL.md 做判断性工作) --"
    echo "  · 把既有规范(.cursorrules/copilot-instructions/…)归并进 docs/conventions 并打 A/B/C 三桶"
    echo "  · 从 pom/package.json 推导回填 AGENTS.md 的项目地图(build/test/run)"
    echo "  · 写 scripts/verify-local.sh 的真实命令(compile→test→smoke)"
    echo "  · 完成后跑  rig doctor  自检"
    echo; echo "提示:hook 变更需开新会话生效。"
    ;;
  *) echo "未知命令: $cmd" >&2; echo >&2; usage >&2; exit 1 ;;
esac
